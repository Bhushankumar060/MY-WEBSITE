# Application Environment Configurations
# Store API keys here securely. For static hosting, these would be injected during a build step
# or used in serverless/Firebase edge functions to prevent exposure in the client side.

# 1. Firebase (Auth, Firestore, Storage)
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=1:your_app_id:web:your_web_id

# 2. OpenAI (GPT-4o) - Used for AI Assistant (Student and Admin)
OPENAI_API_KEY=sk-your_openai_gpt4o_api_key_here

# 3. Polygon.io - Real-time Stock Tickers & Market Data
POLYGON_API_KEY=your_polygon_api_key_here

# 4. Alpha Vantage - Technical Indicators (RSI, MACD, etc)
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key_here

# 5. Finnhub - Financial News & Sentiment
FINNHUB_API_KEY=your_finnhub_api_key_here

# 6. iTick / AllTick - Forex & Crypto Data
ITICK_API_KEY=your_itick_api_key_here
