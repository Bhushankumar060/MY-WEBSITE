generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = "postgresql://admin:password@localhost:5432/resource_kingdom"
}

model Resource {
  id          String   @id @default(uuid())
  title       String
  description String
  category    String
  tags        String[]
  fileUrl     String
  price       Float?
  isPublic    Boolean  @default(true)
  createdAt   DateTime @default(now())
}
